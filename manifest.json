{
  "manifest_version": 3,
  "name": "YouTuned",
  "version": "1.0.0",
  "description": "Remove os blocos de Shorts do YouTube em navegadores compatíveis com extensões e restaura o contador de dislikes.",
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://youtube.com/*",
        "*://m.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://youtube.com/*",
    "*://m.youtube.com/*",
    "https://returnyoutubedislikeapi.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "youtuned@example.com",
      "strict_min_version": "109.0"
    },
    "gecko_android": {
      "strict_min_version": "120.0"
    }
  }
}
