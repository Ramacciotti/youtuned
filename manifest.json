{
  "manifest_version": 3,
  "name": "YouTuned | Remove Shorts, Restaura Dislikes e Filtra Palavras",
  "version": "1.0.1",
  "description": "Remove youtube shorts, restaura dislikes e remove vídeos e comentários com palavras bloqueadas",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "512": "icons/icon512.png"
  },

  "permissions": ["storage"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png",
      "512": "icons/icon512.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "*://youtube.com/*", "*://m.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["*://*.youtube.com/*", "*://youtube.com/*", "*://m.youtube.com/*", "https://returnyoutubedislikeapi.com/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "youtuned@example.com",
      "strict_min_version": "109.0"
    },
    "gecko_android": {
      "strict_min_version": "120.0"
    }
  }
}
